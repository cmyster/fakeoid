// Fakeoid Configuration
// Copy to ~/.fakeoid/config.json and modify as needed.
// Remove all lines starting with // before use (JSON does not support comments).
// Any omitted key uses its default value shown below.
{
  // --- Model Identity (REQUIRED: model_file and model_name must be set) ---
  // HuggingFace repository for the model
  "model_repo": "bartowski/google_gemma-4-31B-it-GGUF",
  // GGUF filename within the repository (REQUIRED)
  "model_file": "google_gemma-4-31B-it-Q4_K_M.gguf",
  // Direct download URL for the model (required for auto-download)
  "model_url": "https://huggingface.co/bartowski/google_gemma-4-31B-it-GGUF/resolve/main/google_gemma-4-31B-it-Q4_K_M.gguf",
  // Expected SHA256 hash for integrity verification (empty = skip verification)
  "model_hash": "",
  // Expected file size in bytes (~19.6 GB, used for progress bar)
  "model_size": 19598483328,
  // Human-readable model name shown in the shell banner (REQUIRED)
  "model_name": "Gemma-4-31B-Q4_K_M",
  // Override the full path to the cached model file (default: ~/.fakeoid/models/<model_file>)
  "model_path": "",

  // --- Server ---
  // Port for the llama-server HTTP API
  "port": 8080,
  // Context window size in tokens (default 32768 = 32K context)
  "ctx_size": 32768,
  // Number of GPU layers to offload (empty or "999" = auto-detect from VRAM, or set manually)
  "gpu_layers": "999",
  // Flash attention mode ("on" or "off")
  "flash_attn": "on",
  // Bind address for llama-server
  "host": "127.0.0.1",
  // Maximum lines kept in the server log buffer
  "log_buffer_max": 200,
  // Percentage of GPU compute units to use (10-100, default 90 = near-idle desktop, no competing GPU compute workloads)
  "gpu_compute_pct": 90,
  // Maximum percentage of GPU VRAM allocatable per request (10-100, default 95 = no competing GPU consumers; 5% OS/driver reserve)
  "gpu_max_alloc_pct": 95,
  // KV cache quantization type for attention keys (q8_0 = half the VRAM of f16,
  // fixes OOM on Gemma 4 31B dual-cache SWA+global at 32K context on 24GB cards).
  // Valid values: f32, f16, bf16, q8_0, q4_0, q4_1, iq4_nl, q5_0, q5_1
  "cache_type_k": "q8_0",
  // KV cache quantization type for attention values (see cache_type_k for rationale)
  // Valid values: f32, f16, bf16, q8_0, q4_0, q4_1, iq4_nl, q5_0, q5_1
  "cache_type_v": "q8_0",

  // --- Timeouts ---
  // Seconds to wait after SIGTERM before sending SIGKILL
  "kill_timeout_seconds": 5,
  // Milliseconds between health check polls during startup
  "health_poll_ms": 500,
  // Milliseconds timeout for each health check HTTP request
  "health_timeout_ms": 2000,
  // Seconds timeout for chat completion HTTP requests
  "chat_timeout_seconds": 10,
  // Seconds to wait for llama-server to become healthy at startup
  "startup_timeout_seconds": 120,
  // Milliseconds between spinner animation frames
  "spinner_interval_ms": 100,

  // --- Token Budget ---
  // Percentage of context window reserved for file injection (Agent 2)
  "token_budget_pct": 60,
  // Percentage of context window that triggers history trimming
  "history_trim_pct": 80,
  // Character-to-token divisor for rough token estimation (chars/N)
  "token_char_divisor": 4,

  // --- UI/Display ---
  // Maximum number of readline history entries
  "history_limit": 500,
  // Fallback terminal width when detection fails
  "terminal_width_fallback": 80,
  // Maximum number of task history records shown at startup
  "startup_history_max": 5,
  // Maximum characters for task name in history table
  "task_name_trunc_len": 40,
  // Maximum characters for generated task filename slugs
  "slug_max_len": 50,

  // --- Filesystem ---
  // Name of the configuration/state directory (under $HOME and project CWD)
  "config_dir_name": ".fakeoid",
  // Subdirectory under config dir for cached models
  "model_subdir": "models",
  // Subdirectory under config dir for task history files
  "task_subdir": "tasks",
  // Filename for the task history index
  "history_file": "history.json",
  // Filename for the user configuration
  "config_file": "config.json",

  // --- File Tree Scanner ---
  // Maximum directory depth for file tree scanning
  "tree_max_depth": 3,
  // Maximum lines in file tree output before truncation
  "tree_max_lines": 200,
  // Directory names to exclude from file tree scans
  "tree_excludes": [".git", "node_modules", "__pycache__", ".venv", "vendor", "build", "dist", ".fakeoid"],

  // --- Sandbox ---
  // Additional read-allowed path prefixes (CWD is always included)
  "read_allow_paths": ["/etc", "/proc"],
  // Allowed build/compile commands for sandbox execution
  "allowed_build_commands": ["cargo", "rustc", "make", "cmake", "gcc", "g++", "clang", "clang++", "npm", "npx", "node", "go", "python", "python3", "pip"],

  // --- Streaming ---
  // Maximum SSE line buffer size in bytes (default 1MB)
  "sse_buffer_size": 1048576,

  // --- Feedback Loop ---
  // Maximum iterations for the Agent 5/6 feedback loop before stopping
  "max_iterations": 100
}
